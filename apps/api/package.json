{
  "name": "@fieldops/api",
  "version": "0.1.0",
  "private": true,
  "description": "Minimal Express API for FieldOps Workflow Tracker.",
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server.js",
    "build": "tsc -p tsconfig.json",
    "test": "tsc -p tsconfig.test.json && node dist/test/tests/health.test.js && node dist/test/tests/database-config.test.js",
    "prisma": "prisma",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "prisma db seed"
  },
  "dependencies": {
    "@prisma/client": "^5.17.0",
    "express": "^4.19.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.10",
    "@types/supertest": "^6.0.2",
    "prisma": "^5.17.0",
    "supertest": "^7.0.0",
    "typescript": "^5.5.3"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  }
}
